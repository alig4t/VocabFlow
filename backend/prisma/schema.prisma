generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  role         Role     @default(USER)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  progress      UserWordProgress[]
  refreshTokens RefreshToken[]
  watchlist     WatchlistItem[]
  plans         LearningPlan[]
  sessions      StudySession[]
  settings      UserSettings?

  @@map("users")
}

enum Role {
  USER
  ADMIN
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model LearningModule {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  order       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")

  words Word[]

  @@map("learning_modules")
}

model Book {
  id          String   @id @default(cuid())
  title       String
  description String?
  coverImage  String?  @map("cover_image")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  volumes   Volume[]
  watchlist WatchlistItem[]

  @@map("books")
}

model WatchlistItem {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  bookId    String   @map("book_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
  @@index([userId])
  @@map("watchlist_items")
}

model Volume {
  id           String   @id @default(cuid())
  bookId       String   @map("book_id")
  volumeNumber Int      @map("volume_number")
  title        String?
  coverImage   String?  @map("cover_image")
  createdAt    DateTime @default(now()) @map("created_at")

  book    Book           @relation(fields: [bookId], references: [id], onDelete: Cascade)
  lessons Lesson[]
  plans   LearningPlan[]

  @@unique([bookId, volumeNumber])
  @@map("volumes")
}

model Lesson {
  id           String   @id @default(cuid())
  volumeId     String   @map("volume_id")
  lessonNumber Int      @map("lesson_number")
  title        String?
  createdAt    DateTime @default(now()) @map("created_at")

  volume Volume @relation(fields: [volumeId], references: [id], onDelete: Cascade)
  words  Word[]

  @@unique([volumeId, lessonNumber])
  @@map("lessons")
}

model Word {
  id                 String   @id @default(cuid())
  eng                String
  per                String
  // English definition (from the source JSON's meanings[].description.eng).
  description        String?
  // Persian rendering of the same definition (meanings[].description.per).
  descriptionPer     String?  @map("description_per")
  pronunciation      String?
  partOfSpeech       String?  @map("part_of_speech")
  wordForms          String?  @map("word_forms")
  synonyms           String[] @default([])
  antonyms           String[] @default([])
  primaryExample     String?  @map("primary_example")
  primaryExampleTrs  String?  @map("primary_example_trs")
  pronunciationAudio String?  @map("pronunciation_audio")
  chapter            Int?
  unit               Int?
  lessonId           String?  @map("lesson_id")
  moduleId           String   @map("module_id")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  module   LearningModule     @relation(fields: [moduleId], references: [id])
  lesson   Lesson?            @relation(fields: [lessonId], references: [id])
  examples WordExample[]
  phrases  WordPhrase[]
  progress UserWordProgress[]

  @@index([moduleId])
  @@index([chapter, unit])
  @@index([lessonId])
  @@map("words")
}

model WordPhrase {
  id         String   @id @default(cuid())
  wordId     String   @map("word_id")
  patternEng String   @map("pattern_eng")
  patternPer String   @map("pattern_per")
  order      Int      @default(0)
  createdAt  DateTime @default(now()) @map("created_at")

  word     Word               @relation(fields: [wordId], references: [id], onDelete: Cascade)
  examples WordPhraseExample[]

  @@index([wordId])
  @@map("word_phrases")
}

model WordPhraseExample {
  id             String @id @default(cuid())
  phraseId       String @map("phrase_id")
  engSentence    String @map("eng_sentence")
  perTranslation String @map("per_translation")
  order          Int    @default(0)

  phrase WordPhrase @relation(fields: [phraseId], references: [id], onDelete: Cascade)

  @@index([phraseId])
  @@map("word_phrase_examples")
}

model WordExample {
  id             String   @id @default(cuid())
  wordId         String   @map("word_id")
  engSentence    String   @map("eng_sentence")
  perTranslation String   @map("per_translation")
  order          Int      @default(0)
  createdAt      DateTime @default(now()) @map("created_at")

  word Word @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@map("word_examples")
}

model UserWordProgress {
  id         String     @id @default(cuid())
  userId     String     @map("user_id")
  wordId     String     @map("word_id")
  reviewMode ReviewMode @map("review_mode")
  // SM-2 daily-program state (written by the "Study Today" flow).
  status WordStatus @default(NOT_READ)
  // Manual free-review mark (written by the /vocabulary/review page). A fully
  // SEPARATE learning track from SM-2 — never touched by the daily program.
  manualStatus WordStatus @default(NOT_READ) @map("manual_status")

  // ─── SM-2 spaced-repetition scheduling ───────────────────────────────────────
  repetitions    Int       @default(0)
  intervalDays   Int       @default(0) @map("interval_days")
  easeFactor     Float     @default(2.5) @map("ease_factor")
  reviewCount    Int       @default(0) @map("review_count")
  correctCount   Int       @default(0) @map("correct_count")
  wrongCount     Int       @default(0) @map("wrong_count")
  lastReviewedAt DateTime? @map("last_reviewed_at")
  nextReviewAt   DateTime? @map("next_review_at")
  // Timestamp the word first entered the learning cycle (null = never introduced,
  // i.e. still a "new word" candidate for the daily quota).
  introducedAt DateTime? @map("introduced_at")

  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  word Word @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@unique([userId, wordId, reviewMode])
  @@index([userId, reviewMode])
  @@index([userId, reviewMode, nextReviewAt])
  @@map("user_word_progress")
}

/// A user's learning plan for a single volume: the source of truth for the
/// "my learning list". Replaces the book-level watchlist as the driver of the
/// daily study system (new-word introduction + review scheduling).
model LearningPlan {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  volumeId      String   @map("volume_id")
  dailyNewWords Int      @default(10) @map("daily_new_words")
  dailyGoal     Int      @default(30) @map("daily_goal")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  volume Volume @relation(fields: [volumeId], references: [id], onDelete: Cascade)

  @@unique([userId, volumeId])
  @@index([userId])
  @@map("learning_plans")
}

/// One completed daily study session — powers the end-of-session summary,
/// the study streak, the activity heatmap, and accuracy statistics.
model StudySession {
  id            String    @id @default(cuid())
  userId        String    @map("user_id")
  startedAt     DateTime  @map("started_at")
  endedAt       DateTime? @map("ended_at")
  durationSec   Int       @default(0) @map("duration_sec")
  reviewedCount Int       @default(0) @map("reviewed_count")
  correctCount  Int       @default(0) @map("correct_count")
  wrongCount    Int       @default(0) @map("wrong_count")
  hardCount     Int       @default(0) @map("hard_count")
  skippedCount  Int       @default(0) @map("skipped_count")
  newCount      Int       @default(0) @map("new_count")
  createdAt     DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startedAt])
  @@map("study_sessions")
}

/// Per-user global preferences. `dailyNewWords`/`dailyGoal` live on
/// `LearningPlan` (per volume); these are the app-wide study settings.
model UserSettings {
  userId         String     @id @map("user_id")
  studyDirection ReviewMode @default(EN_TO_FA) @map("study_direction")
  autoPlayAudio  Boolean    @default(true) @map("auto_play_audio")
  showPhonetics  Boolean    @default(true) @map("show_phonetics")
  showExamples   Boolean    @default(true) @map("show_examples")
  cardOrder      CardOrder  @default(SEQUENTIAL) @map("card_order")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

enum CardOrder {
  SEQUENTIAL
  RANDOM
}

enum ReviewMode {
  EN_TO_FA
  FA_TO_EN
}

enum WordStatus {
  NOT_READ
  KNOWN
  NOT_KNOWN
}

model SynonymGroup {
  id          String   @id @default(cuid())
  conceptName String   @map("concept_name")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("synonym_groups")
}
